# Copy to grok-secrets.env (same folder) — never commit grok-secrets.env
# Get TMDB key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key-here
# Optional — feel search trivia + video generation
XAI_API_KEY=your-xai-api-key-here
# Optional — X.com stream announcements
X_BEARER_TOKEN=your-x-bearer-token-here