#!/bin/bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
UI_DIR="$ROOT/resolve/ui"
BIN="$ROOT/bin/grok-menu-ui"
PLIST="$ROOT/resolve/ui/Info.plist"
export GROK_PUBLIC_FOLDER="$ROOT"

if [[ ! -f "$UI_DIR/GrokMenu.swift" ]]; then
  echo "missing $UI_DIR/GrokMenu.swift" >&2
  exit 1
fi

if [[ ! -f "$ROOT/project/generate-ui.json" ]] \
  || [[ "$ROOT/grok_generate_catalog.py" -nt "$ROOT/project/generate-ui.json" ]]; then
  python3 "$ROOT/grok_generate_catalog.py" >/dev/null 2>&1 || true
fi

needs_rebuild() {
  [[ ! -x "$BIN" ]] && return 0
  [[ -f "$PLIST" && "$PLIST" -nt "$BIN" ]] && return 0
  find "$UI_DIR" -maxdepth 1 -name '*.swift' -newer "$BIN" -print -quit | grep -q .
}

if needs_rebuild; then
  if [[ -f "$PLIST" ]]; then
    swiftc -O -o "$BIN" "$UI_DIR"/*.swift -framework AppKit -framework AVKit -framework AVFoundation \
      -Xlinker -sectcreate -Xlinker __TEXT -Xlinker __info_plist -Xlinker "$PLIST" 2>/dev/null || true
  else
    swiftc -O -o "$BIN" "$UI_DIR"/*.swift -framework AppKit -framework AVKit -framework AVFoundation 2>/dev/null || true
  fi
fi

if [[ -x "$BIN" ]]; then
  exec "$BIN" "$@"
fi

exec /usr/bin/swift "$UI_DIR"/*.swift "$@"