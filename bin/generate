#!/bin/bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export GROK_PUBLIC_FOLDER="$ROOT"
cd "$ROOT" || exit 1
# shellcheck source=/dev/null
source "$ROOT/bin/grok-trust"

grok_trust_banner "Generate Video" "$ROOT"

if [[ -z "${XAI_API_KEY:-}" ]]; then
  echo ""
  echo "ERROR: XAI_API_KEY is not set."
  echo "This Grok workflow talks only to x.ai using your own API key."
  echo "Run:  export XAI_API_KEY=your-key"
  echo "Key:  https://console.x.ai"
  exit 1
fi

echo "Starting x.ai video generation…"
exec python3 "$ROOT/grok_menu_cli.py" generate "$@"